DATABASE_URL=postgresql://kendra:kendra@localhost:5432/kendra

# JWT session secret (any long random string, >= 32 chars)
SESSION_SECRET=change-me-to-a-long-random-string-of-at-least-32-bytes

# Admin dashboard credentials (email + password, checked server-side only)
ADMIN_EMAIL=admin@kendra.in
ADMIN_PASSWORD=change-me-strong-password

# Firebase web client (Project settings > General > Your apps > Web)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (service account JSON, server-only)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Paste the full PEM. Keep literal \n for line breaks.
FIREBASE_ADMIN_PRIVATE_KEY=

# ImageKit
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=
IMAGEKIT_PRIVATE_KEY=